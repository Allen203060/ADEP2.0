# Winsorizing the outliers:
df[numerical_cols] = df[numerical_cols].clip(lower=(Q1 - 1.5 * iqr), upper=(Q3 + 1.5 * iqr), axis=0)

# Updating the raw data:
SHARED_GLOBALS['raw_data'] = df

print('Outliers have been Winsorized.')
