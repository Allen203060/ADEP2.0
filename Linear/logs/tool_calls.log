Here is the corrected code:

```python
import pandas as pd

# Accessing the raw data:
df = SHARED_GLOBALS['raw_data']

# Check if SHARED_GLOBALS exists
def check_shared_globals():
    if not hasattr(globals(), 'SHARED_GLOBALS'):
        raise ValueError('SHARED_GLOBALS is not defined.')

try:
    check_shared_globals()

    # Identify missing values in numerical and categorical columns
    cat_cols = df.select_dtypes(include=['object']).columns
    num_cols = df.select_dtypes(exclude=['object']).columns

    # Impute missing values in numerical columns with median
    df[num_cols] = df[num_cols].fillna(df[num_cols].median())

    # Impute missing values in categorical columns with mode
    df[cat_cols] = df[cat_cols].fillna(df[cat_cols].mode().iloc[0])

    # Update the raw data in SHARED_GLOBALS
    copy_df = df.copy()
    SHARED_GLOBALS['raw_data'] = copy_df

    print('Missing values imputed.')

except ValueError as e:
    print(f'Error: {e}')
```

