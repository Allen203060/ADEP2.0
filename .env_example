# =========================================================================
# ADEP Orchestrator Configuration
# =========================================================================
# Active settings
# Options: google, ollama, openrouter, nvidia
ADEP_PROVIDER=google
ADEP_MODEL_NAME=gemini-2.0-flash

# --- Google Gemini ---
# (Used when ADEP_PROVIDER=google)
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenRouter ---
# (Used when ADEP_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- NVIDIA NIM / Nemotron ---
# (Used when ADEP_PROVIDER=nvidia)
NVIDIA_API_KEY=your_nvidia_api_key_here

# --- Ollama ---
# (Used when ADEP_PROVIDER=ollama)
OLLAMA_API_BASE=http://localhost:11434
